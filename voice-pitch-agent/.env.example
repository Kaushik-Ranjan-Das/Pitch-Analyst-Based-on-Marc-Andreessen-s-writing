# Anthropic API key for Claude Sonnet 4.6 (the Aparna agent).
# Get one at https://console.anthropic.com/settings/keys
# Stays server-side — Vite proxies /api/anthropic and injects this header.
ANTHROPIC_API_KEY=sk-ant-...

# Voyage AI API key for embeddings used by the RAG retrieval over the
# Marc Andreessen corpus in ../marc-agent/data/. Free tier at
# https://dash.voyageai.com/. Used by:
#   - scripts/build-index.mjs (one-time index build, batch=128)
#   - vite.config.js /api/retrieve middleware (one query embedding per turn)
VOYAGE_API_KEY=pa-...

# Optional: override the Claude model. Defaults to claude-sonnet-4-6.
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional: override the embedding model. Defaults to voyage-3.5-lite.
# VOYAGE_MODEL=voyage-3.5-lite
